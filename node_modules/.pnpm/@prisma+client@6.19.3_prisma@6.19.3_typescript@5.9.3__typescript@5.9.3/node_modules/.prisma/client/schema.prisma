generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleType {
  USER
  ADMIN
}

enum GoalType {
  GAIN_MUSCLE
  LOSE_FAT
  RECOMPOSITION
  STRENGTH
  ENDURANCE
}

enum SexType {
  MALE
  FEMALE
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         RoleType @default(USER)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  profile          Profile?
  routines         Routine[]
  createdExercises Exercise[]       @relation("CreatedExercises")
  workoutSessions  WorkoutSession[]
  progressRecords  ProgressRecord[]

  @@map("users")
}

model Profile {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @unique @map("user_id") @db.Uuid
  firstName      String   @map("first_name")
  lastName       String   @map("last_name")
  birthDate      DateTime @map("birth_date") @db.Date
  sex            SexType
  heightCm       Decimal  @map("height_cm") @db.Decimal(5, 2)
  weightKg       Decimal  @map("weight_kg") @db.Decimal(6, 2)
  targetWeightKg Decimal? @map("target_weight_kg") @db.Decimal(6, 2)
  goal           GoalType
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model ExerciseCategory {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  exercises Exercise[]

  @@map("exercise_categories")
}

model Exercise {
  id              String    @id @default(uuid()) @db.Uuid
  categoryId      String    @map("category_id") @db.Uuid
  createdByUserId String?   @map("created_by_user_id") @db.Uuid
  isSystem        Boolean   @default(false) @map("is_system")
  name            String
  description     String?
  equipment       String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  category         ExerciseCategory  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  createdBy        User?             @relation("CreatedExercises", fields: [createdByUserId], references: [id], onDelete: SetNull)
  routineExercises RoutineExercise[]
  exerciseLogs     ExerciseLog[]

  @@index([categoryId])
  @@index([createdByUserId])
  @@index([deletedAt])
  @@index([createdByUserId, deletedAt])
  @@index([categoryId, deletedAt])
  @@map("exercises")
}

model Routine {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  name        String
  description String?
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  days            RoutineDay[]
  workoutSessions WorkoutSession[]

  @@index([userId])
  @@index([userId, isActive])
  @@index([userId, deletedAt])
  @@map("routines")
}

model RoutineDay {
  id        String   @id @default(uuid()) @db.Uuid
  routineId String   @map("routine_id") @db.Uuid
  dayNumber Int      @map("day_number")
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  routine   Routine           @relation(fields: [routineId], references: [id], onDelete: Cascade)
  exercises RoutineExercise[]

  @@unique([routineId, dayNumber])
  @@index([routineId])
  @@map("routine_days")
}

model RoutineExercise {
  id             String   @id @default(uuid()) @db.Uuid
  routineDayId   String   @map("routine_day_id") @db.Uuid
  exerciseId     String   @map("exercise_id") @db.Uuid
  sets           Int
  reps           Int
  targetWeightKg Decimal? @map("target_weight_kg") @db.Decimal(6, 2)
  restSeconds    Int?     @map("rest_seconds")
  orderIndex     Int      @map("order_index")
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  routineDay RoutineDay @relation(fields: [routineDayId], references: [id], onDelete: Cascade)
  exercise   Exercise   @relation(fields: [exerciseId], references: [id], onDelete: Restrict)

  @@unique([routineDayId, orderIndex])
  @@index([routineDayId])
  @@index([exerciseId])
  @@map("routine_exercises")
}

model ProgressRecord {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  weightKg          Decimal  @map("weight_kg") @db.Decimal(6, 2)
  bodyFatPercentage Decimal? @map("body_fat_percentage") @db.Decimal(5, 2)
  muscleMassKg      Decimal? @map("muscle_mass_kg") @db.Decimal(6, 2)
  notes             String?
  recordDate        DateTime @map("record_date") @db.Date
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, recordDate])
  @@index([userId])
  @@index([recordDate])
  @@map("progress_records")
}

model WorkoutSession {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  routineId       String   @map("routine_id") @db.Uuid
  sessionDate     DateTime @map("session_date") @db.Date
  durationMinutes Int?     @map("duration_minutes")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  routine      Routine       @relation(fields: [routineId], references: [id], onDelete: Restrict)
  exerciseLogs ExerciseLog[]

  @@index([userId])
  @@index([routineId])
  @@index([sessionDate])
  @@index([userId, sessionDate])
  @@map("workout_sessions")
}

model ExerciseLog {
  id               String   @id @default(uuid()) @db.Uuid
  workoutSessionId String   @map("workout_session_id") @db.Uuid
  exerciseId       String   @map("exercise_id") @db.Uuid
  sets             Int
  reps             Int
  weightKg         Decimal? @map("weight_kg") @db.Decimal(6, 2)
  notes            String?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  workoutSession WorkoutSession @relation(fields: [workoutSessionId], references: [id], onDelete: Cascade)
  exercise       Exercise       @relation(fields: [exerciseId], references: [id], onDelete: Restrict)

  @@index([workoutSessionId])
  @@index([exerciseId])
  @@map("exercise_logs")
}
